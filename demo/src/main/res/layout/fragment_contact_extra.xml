<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aw_demo_bg"
    android:orientation="vertical"
    android:padding="@dimen/demo_space_md">

    <TextView
        android:id="@+id/tvBreadcrumb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/aw_demo_wechat"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/demo_space_md"
        android:text="@string/wechat_contact_layer_3"
        android:textColor="@color/aw_demo_on_surface"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/demo_space_sm"
        android:textColor="@color/aw_demo_on_surface_muted"
        android:textSize="15sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/demo_space_lg"
        android:lineSpacingExtra="4dp"
        android:text="演示：联系人标签、共同群聊等可放在这一层。连续按返回键经 AwNav 逐级出栈。"
        android:textColor="@color/aw_demo_on_surface"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/demo_space_md"
        android:text="@string/wechat_tip_system_back"
        android:textColor="@color/aw_demo_on_surface_muted"
        android:textSize="12sp" />
</LinearLayout>
