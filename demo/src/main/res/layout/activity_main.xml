<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aw_demo_surface_muted">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/aw_demo_bg">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/demo_main_title"
            app:titleTextColor="@color/aw_demo_on_surface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/demo_space_md"
            android:paddingEnd="@dimen/demo_space_md"
            android:paddingBottom="@dimen/demo_space_md"
            android:text="@string/demo_main_subtitle"
            android:textColor="@color/aw_demo_on_surface_muted"
            android:textSize="14sp" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/demo_space_md">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.AwArchDemo.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/demo_space_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="演示清单"
                        android:textColor="@color/aw_demo_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/demo_space_sm"
                        android:text="请选择一个功能进入独立页面操作与查看日志"
                        android:textColor="@color/aw_demo_on_surface_muted"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlaybook"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/demo_space_sm"
                        android:text="@string/demo_playbook" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="@string/demo_section_state"
                android:textColor="@color/aw_demo_on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLoadState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="LoadState 加载（新页面）" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetryLoadState"
                style="@style/Widget.AwArchDemo.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_lg"
                android:text="重试（3 次指数退避，新页面）" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="@string/demo_section_bus"
                android:textColor="@color/aw_demo_on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPostEvent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="FlowEventBus：post（新页面）" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTryPostEvent"
                style="@style/Widget.AwArchDemo.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="FlowEventBus：tryPost（新页面）" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStickyEvent"
                style="@style/Widget.AwArchDemo.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="FlowEventBus：postSticky（新页面）" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoveSticky"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_lg"
                android:text="FlowEventBus：removeSticky（新页面）" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="@string/demo_section_arch"
                android:textColor="@color/aw_demo_on_surface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMvvm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                style="@style/Widget.AwArchDemo.Button.Outlined"
                android:text="MVVM" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMvi"
                style="@style/Widget.AwArchDemo.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="MVI" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMvp"
                style="@style/Widget.AwArchDemo.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="MVP" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNav"
                style="@style/Widget.AwArchDemo.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                android:text="AwNav（路由演示）" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWeChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/demo_space_sm"
                style="@style/Widget.AwArchDemo.Button.Outlined"
                android:text="AwNav（微信式多 Tab）" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
