<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/aw_demo_surface_muted">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/demo_space_sm"
        android:background="@color/aw_demo_surface"
        android:elevation="2dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHome"
            style="@style/Widget.AwArchDemo.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Home"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetail"
            style="@style/Widget.AwArchDemo.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/demo_space_sm"
            android:layout_weight="1"
            android:text="Detail"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.AwArchDemo.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/demo_space_sm"
            android:layout_weight="1"
            android:text="Back"
            android:textSize="12sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvInterceptStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/aw_demo_log_bg"
        android:padding="@dimen/demo_space_sm"
        android:text="拦截 Detail：开启（点击切换）"
        android:textColor="@color/aw_demo_on_surface_muted"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleIntercept"
        style="@style/Widget.AwArchDemo.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/demo_space_sm"
        android:layout_marginEnd="@dimen/demo_space_sm"
        android:layout_marginTop="@dimen/demo_space_sm"
        android:layout_marginBottom="@dimen/demo_space_sm"
        android:text="切换：是否拦截 navigate → detail" />

    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>

