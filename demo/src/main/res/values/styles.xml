<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.AwArchDemo.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">@color/aw_demo_divider</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.AwArchDemo.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/aw_demo_divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.AwArchDemo.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/aw_demo_divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.AwArchDemo.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/aw_demo_divider</item>
    </style>

</resources>

